GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
PORT=3001
CLIENT_URL=http://localhost:5173

# Railway: set CLIENT_URL to your public app URL (e.g. https://your-service.up.railway.app).
# Add a volume mount and set STACKWISE_DATA_DIR=/data so SQLite survives redeploys (e.g. /data/stackwise.db).

# Production: HS256 secret for JWT sessions (min 32 characters). Required when NODE_ENV=production.
# JWT_SECRET=

# SQLite data directory (default: server process cwd). Database file: stackwise.db
# STACKWISE_DATA_DIR=

# PayPal REST (server): used to verify subscriptions and webhooks
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# PAYPAL_API_BASE=https://api-m.paypal.com
# Plan IDs must match the plans used in the client checkout
# PAYPAL_BASIC_PLAN_ID=
# PAYPAL_PRO_PLAN_ID=
# Webhook id from PayPal Developer dashboard (signature verification for POST /api/webhooks/paypal)
# PAYPAL_WEBHOOK_ID=

# Stripe (optional — card checkout on /pricing when client VITE_STRIPE_CHECKOUT=true)
# Create Products with recurring prices in dashboard.stripe.com → use price_… IDs for Basic and Pro.
# Webhook endpoint: POST https://your-api-origin/api/webhooks/stripe — enable checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_BASIC=price_...
# STRIPE_PRICE_PRO=price_...

# API auth: set true to enforce JWT on protected routes. Use true locally too for billing/Stripe/PayPal activate.
# STACKWISE_REQUIRE_API_AUTH=true

# Optional: require this value in header x-stackwise-analyze on POST /api/analyze (set same in client VITE_ANALYZE_SECRET)
# For a public production app, leave ANALYZE_SECRET unset unless you intentionally lock /api/analyze to your SPA only.
# ANALYZE_SECRET=
# Optional: max stack builds per IP per hour (default 30)
# ANALYZE_MAX_PER_HOUR=30

# Client build only: override the small V#.#.# label in the SPA (otherwise uses client/package.json version).
# STACKWISE_APP_VERSION_OVERRIDE=1.0.42

# Amazon Associates: set in client/.env as VITE_AMAZON_ASSOCIATE_TAG (see client/.env.example)

# Email sending via Resend (resend.com — free tier: 3,000 emails/month)
# 1) Add domain stack-wise.org in Resend → Domains, create DNS records (SPF/DKIM) until verified.
# 2) RESEND_FROM_EMAIL must use that domain (e.g. stacky@stack-wise.org). Unverified domains are rejected by the API.
# 3) Get API key at resend.com/api-keys — without RESEND_API_KEY the server only logs magic links to the console.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=stacky@stack-wise.org
# App public URL — used to build magic link URLs
# APP_URL=https://yourdomain.com

# Supabase Auth (optional). JWT Secret from Supabase → Project Settings → API (not the anon key).
# Required for the API to accept Supabase access tokens: same value as "JWT Secret" in the dashboard.
# SUPABASE_JWT_SECRET=

# Product analytics: POST /api/analytics/event logs JSON lines as [analytics] ... (grep logs or pipe to a warehouse).
# Set both to the same random string so only your SPA can ingest (optional in local dev).
# ANALYTICS_INGEST_KEY=
# ANALYTICS_ENABLED=true
# ANALYTICS_LOG_IP=false

# Sign-in (recommended without client Supabase): server sends magic links via Resend.
# Set RESEND_API_KEY, RESEND_FROM_EMAIL (verified domain in Resend), APP_URL, CLIENT_URL. Do not set VITE_SUPABASE_* in the client build.
# Optional: if you add VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY to the client, Supabase sends OTP instead; then set Supabase Auth URL config for production (Site URL + /auth/callback).
