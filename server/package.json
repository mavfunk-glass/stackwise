{
  "name": "stackwise-server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "diagnose:personalization": "tsx src/scripts/diagnosePersonalization.ts",
    "reset:free-tier": "tsx src/scripts/resetFreeTierLocal.ts",
    "create-paypal-plans": "tsx src/scripts/createPaypalPlans.ts",
    "railway:env-paste": "tsx src/scripts/writeRailwayEnvPaste.ts",
    "paypal:register-webhook": "tsx src/scripts/registerPaypalWebhook.ts",
    "verify:payments": "tsx src/scripts/verifyPaymentReadiness.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jose": "^6.2.2",
    "node-cron": "^4.2.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
