# Email sending via Resend (resend.com — free tier: 3,000 emails/month)
# Get your API key at resend.com/api-keys
# RESEND_API_KEY=re_...
# From address for magic link emails (must be a verified domain in Resend)
# RESEND_FROM_EMAIL=stacky@yourdomain.com
# App public URL — used to build magic link URLs
# APP_URL=https://yourdomain.com

# ── Email (Resend) ─────────────────────────────────────────────────────────
# Sign up at resend.com — free tier is 3,000 emails/month
# Without RESEND_API_KEY, emails are logged to console (dev mode)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Must be a verified sender domain in your Resend account
# RESEND_FROM_EMAIL=stacky@yourdomain.com

# ── App URL ────────────────────────────────────────────────────────────────
# Used to build magic link and check-in URLs in emails
# APP_URL=https://yourdomain.com
