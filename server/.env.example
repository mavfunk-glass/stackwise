# This file is loaded after the repo-root .env (see server/src/index.ts). Use either location for secrets.

# Email sending via Resend (resend.com — free tier: 3,000 emails/month)
# Verify stack-wise.org in Resend (DNS SPF/DKIM) before using stacky@stack-wise.org as RESEND_FROM_EMAIL.
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=stacky@stack-wise.org
# APP_URL=https://yourdomain.com

# ── Email (Resend) ─────────────────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=stacky@stack-wise.org

# ── App URL ────────────────────────────────────────────────────────────────
# Used to build magic link and check-in URLs in emails
# APP_URL=https://yourdomain.com
