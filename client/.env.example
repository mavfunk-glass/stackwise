# App version label (V1.0.0): bump patch anytime with `npm run version:patch` from repo root or client/
# (updates client/package.json). For major v2, edit client/package.json version to 2.0.0.
# Optional build-time override (host/CI): set STACKWISE_APP_VERSION_OVERRIDE in the environment when running vite build.

# When the built SPA is on a different host than the Express API, set the API origin (no trailing slash).
# Leave unset for local dev (Vite proxies /api) or same-origin production behind one reverse proxy.
# VITE_API_BASE_URL=https://your-api.example.com

# Supabase Auth (optional). URL + anon JWT from Project Settings → API.
# Redirect URL in Supabase must include: http://localhost:5173/auth/callback
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# Amazon Associates store ID / tracking id (adds &tag=... to every Amazon buy link).
# Example: yoursite-20
VITE_AMAZON_ASSOCIATE_TAG=

# PayPal JS SDK (public client id; must match server PayPal app)
# VITE_PAYPAL_CLIENT_ID=

# Plan IDs for subscribe buttons (must match server PAYPAL_BASIC_PLAN_ID / PAYPAL_PRO_PLAN_ID)
# VITE_PAYPAL_BASIC_PLAN_ID=
# VITE_PAYPAL_PRO_PLAN_ID=

# Supabase Auth (real accounts). Get URL + anon key from Supabase → Project Settings → API.
# Add redirect URL in Supabase: http://localhost:5173/auth/callback (and your production URL).
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=

# Dev server only: "true" unlocks Pro in the UI without PayPal. Remove or set false to test free tier.
VITE_DEV_PRO=

# Optional: must match server ANALYZE_SECRET or POST /api/analyze returns 401
# VITE_ANALYZE_SECRET=

# Optional: must match server ANALYTICS_INGEST_KEY when that is set (product event ingest)
# VITE_ANALYTICS_INGEST_KEY=

# iHerb referral code (adds &rcode=... to every iHerb buy link; get yours at iherb.com/affiliates)
# VITE_IHERB_RCODE=

# Amazon Associates tag for affiliate buy links
# VITE_AMAZON_ASSOCIATE_TAG=

# iHerb referral code for affiliate buy links
# VITE_IHERB_RCODE=
